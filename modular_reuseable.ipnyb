        "def status(markah):\n",
        "  if markah >= 50:\n",
        "    return \"Anda lulus!\"\n",
        "  else:\n",
        "    return \"Anda gagal...\"\n",
        "\n",
        "asd = status(50)\n",
        "print(f\"Tahniah! {asd}\")"
      ],
      "metadata": {
