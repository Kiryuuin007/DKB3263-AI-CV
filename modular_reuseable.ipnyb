      "cell_type": "code",
      "source": [
        "def tambah(a,b):\n",
        "  return a+b\n",
        "\n",
        "def tolak(a,b):\n",
        "  return a-b\n",
        "\n",
        "print(\"Tambah = \", tambah(a=10,b=5))\n",
        "print(\"Tolak = \", tolak(a=10,b=5))"
      ],
      "metadata": {
        "colab": {
