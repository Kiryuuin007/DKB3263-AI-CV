    {
      "cell_type": "code",
      "source": [
        "def bmi(berat, tinggi):\n",
        "  return berat / (tinggi*tinggi)\n",
        "\n",
        "BMI = bmi(167, 12)\n",
        "print(f\"bmi = {BMI}\")"
      ],
