    {
      "cell_type": "code",
      "source": [
        "def kira_luas(panjang, lebar):\n",
        "    return panjang*lebar\n",
        "\n",
        "luas = kira_luas(12,5)\n",
        "print(f\"luas = {luas}\")\n",
        "\n",
        "luas2 = kira_luas(6,7)\n",
        "print(f\"luas 67 = {luas2}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 107
        },
        "id": "MvDfexnbGEaB",
        "outputId": "32608969-30e5-466f-befe-5cb98caff482"
      },
      "execution_count": 27,
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<IPython.core.display.HTML object>"
            ],
            "text/html": [
              "\n",
              "     <input type=\"file\" id=\"files-85dbc1f1-afbe-4e52-affd-cff5d8e72560\" name=\"files[]\" multiple disabled\n",
              "        style=\"border:none\" />\n",
              "     <output id=\"result-85dbc1f1-afbe-4e52-affd-cff5d8e72560\">\n",
